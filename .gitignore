# Run outputs — everything except the explainer README
runs/*
!runs/README.md

# Demo-recording pipeline outputs (scripts/record_demo/) — the pipeline
# itself is versioned, its renders are not.
scripts/record_demo/*.cast
scripts/record_demo/*.mp4
scripts/record_demo/*.gif
scripts/record_demo/*.webm

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# Testing / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors / OS
.vscode/
.idea/
*.swp
.DS_Store

# Local Claude Code state (keep .claude/skills and .claude/commands versioned)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Secrets — belt and braces; nothing in this repo should ever need one
.env
*.pem
